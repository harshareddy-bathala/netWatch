# NetWatch Production Environment
# Copy to: /etc/netwatch/netwatch.env
# chmod 600 /etc/netwatch/netwatch.env

# REQUIRED: Set a strong random secret key
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# REQUIRED: API key for authentication
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
NETWATCH_API_KEY=CHANGE_ME_TO_A_RANDOM_API_KEY

# Authentication (enabled by default in production)
NETWATCH_AUTH_ENABLED=true

# Database path (default: /var/lib/netwatch/netwatch.db)
DATABASE_PATH=/var/lib/netwatch/netwatch.db

# Connection pool size (15 for production)
DB_CONNECTION_POOL_SIZE=15

# Flask bind address (bind to localhost; use reverse proxy for external access)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# CORS origins (restrict to your domain in production)
# Comma-separated list
CORS_ORIGINS=https://your-domain.example.com

# Log level
LOG_LEVEL=INFO

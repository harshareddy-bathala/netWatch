# ===========================================================================
# NetWatch Environment Configuration
# ===========================================================================
# Copy this file to .env and adjust values for your deployment.
#
#   cp .env.example .env        # Linux / macOS
#   copy .env.example .env      # Windows
#
# The application reads these via os.getenv() in config.py.
# ===========================================================================

# Application environment: development | production | testing
NETWATCH_ENV=production

# ── Flask / Waitress ──────────────────────────────────────────────────────
# Bind address: 127.0.0.1 = localhost only (secure default)
# Set to 0.0.0.0 to listen on all interfaces (required for Docker / remote access)
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
WAITRESS_THREADS=8

# ── Secret key (REQUIRED in production – generate with the command below) ─
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_BEFORE_DEPLOYING

# ── Database ──────────────────────────────────────────────────────────────
# Leave empty to use the platform default:
#   Windows  → %PROGRAMDATA%\NetWatch\netwatch.db
#   Linux    → /var/lib/netwatch/netwatch.db
#   Dev mode → ./netwatch.db  (project root)
# DATABASE_PATH=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=/var/log/netwatch/netwatch.log

# ── Network ───────────────────────────────────────────────────────────────
# Force a specific interface (None = auto-detect)
# NETWORK_INTERFACE=eth0
